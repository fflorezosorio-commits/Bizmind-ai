rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 4. Entity Validations
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.keys().size() <= 6 &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             (data.get('displayName', '') is string && data.get('displayName', '').size() <= 128) &&
             (data.get('photoURL', '') is string && data.get('photoURL', '').size() <= 512);
    }

    // 5. Collection Rules
    match /users/{userId} {
      allow get: if isOwner(userId);
      
      allow create: if isOwner(userId) && 
                      isValidId(userId) &&
                      isValidUser(incoming()) &&
                      incoming().uid == userId &&
                      incoming().createdAt == request.time &&
                      incoming().lastLogin == request.time;
      
      allow update: if isOwner(userId) &&
                      isValidUser(incoming()) &&
                      incoming().uid == existing().uid &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().lastLogin == request.time &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'lastLogin']);
      
      allow delete: if false; // Users cannot delete profiles via client
    }
  }
}
